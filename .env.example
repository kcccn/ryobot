# RyoBot environment configuration
# Copy this file to .env and fill in your values.

# --- Required ---

# GitHub token for API access (Actions: ${{ github.token }})
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# At least one LLM API key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# GitHub event payload (Actions: ${{ toJson(github.event) }})
# EVENT_PAYLOAD=

# Full repo slug (Actions: ${{ github.repository }})
GITHUB_REPOSITORY=owner/repo

# --- Bot Identity ---

# Which bot to run: architect, reviewer, pm, explorer, coder
BOT_IDENTITY=architect

# --- Optional LLM ---

# Custom LLM endpoint (defaults to DeepSeek)
# LLM_BASE_URL=https://api.deepseek.com

# Override the default model
# LLM_MODEL=deepseek-chat

# --- Optional Behavior Tuning ---

# Max ReAct loop iterations (default: 100)
# MAX_ITERATIONS=100

# Fatigue cooldown in seconds (min/max, defaults: 480/720)
# RYOBOT_FATIGUE_MIN_SECONDS=480
# RYOBOT_FATIGUE_MAX_SECONDS=720

# Bot activity weights: comma-separated identity=weight pairs
# Example: architect=0.3,reviewer=0.3,pm=0.2,explorer=0.2
# RYOBOT_BOT_ACTIVITY_WEIGHTS=

# --- Optional History Budget ---

# Initial history comment limit (default: 12)
# RYOBOT_INITIAL_HISTORY_COMMENT_LIMIT=12

# Initial history total chars (default: 16000)
# RYOBOT_INITIAL_HISTORY_TOTAL_CHARS=16000

# --- Optional Character Limits ---

# Max chars per tool result (default: 20000)
# RYOBOT_MAX_TOOL_RESULT_CHARS=20000

# Max chars per history comment (default: 12000)
# RYOBOT_MAX_HISTORY_COMMENT_CHARS=12000

# Max total history chars (default: 80000)
# RYOBOT_MAX_HISTORY_TOTAL_CHARS=80000

# Max diff chars for code review (default: 50000)
# RYOBOT_MAX_DIFF_CHARS=50000

# Max file chars for read_file (default: 30000)
# RYOBOT_MAX_FILE_CHARS=30000

# --- Optional Security ---

# Comma-separated allowed workflow names for dispatch_workflow skill
# RYOBOT_ALLOWED_WORKFLOWS=

# Git ref to run allowed workflows from (default: main)
# RYOBOT_ALLOWED_WORKFLOW_REFS=main

# Comma-separated allowed shell commands for run_command skill
# RYOBOT_ALLOWED_COMMANDS=

# Timeout in seconds for run_command executions (default: 300)
# RYOBOT_COMMAND_TIMEOUT_SECONDS=300

# Comma-separated GitHub logins that can embed state markers (default: github-actions[bot])
# RYOBOT_MARKER_AUTHOR_LOGINS=github-actions[bot]
